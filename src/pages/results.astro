---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Results | PIVOT Management Consultants" description="Proof, not promises. Real outcomes from operational interventions across aerospace, medical devices, manufacturing, and healthcare.">
  <section class="py-12 sm:py-16 border-b border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="font-heading italic text-ink-muted text-sm mb-2">Results — not reports.</p>
      <h1 class="text-[1.75rem] sm:text-[2rem] lg:text-[2.25rem] text-ink mb-2">
        Proof, not promises.
      </h1>
      <p class="text-sm sm:text-base text-ink-light max-w-2xl">
        Every engagement ships measurable results. Here's what clients and colleagues say about working with PIVOT.
      </p>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-12 sm:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-lg sm:text-xl mb-6">What clients say</h2>
      <div class="grid sm:grid-cols-2 gap-6 mb-8">
        <!-- Testimonial 1 placeholder -->
        <div class="rounded-lg p-6 border border-border bg-surface-alt">
          <blockquote class="text-sm text-ink-light italic leading-relaxed mb-4">
            &ldquo;Client testimonial coming soon.&rdquo;
          </blockquote>
          <div class="text-sm">
            <p class="font-semibold text-ink">Client Name</p>
            <p class="text-ink-muted text-xs">Title, Company</p>
          </div>
        </div>
        <!-- Testimonial 2 placeholder -->
        <div class="rounded-lg p-6 border border-border bg-surface-alt">
          <blockquote class="text-sm text-ink-light italic leading-relaxed mb-4">
            &ldquo;Client testimonial coming soon.&rdquo;
          </blockquote>
          <div class="text-sm">
            <p class="font-semibold text-ink">Client Name</p>
            <p class="text-ink-muted text-xs">Title, Company</p>
          </div>
        </div>
        <!-- Testimonial 3 placeholder -->
        <div class="rounded-lg p-6 border border-border bg-surface-alt">
          <blockquote class="text-sm text-ink-light italic leading-relaxed mb-4">
            &ldquo;Client testimonial coming soon.&rdquo;
          </blockquote>
          <div class="text-sm">
            <p class="font-semibold text-ink">Client Name</p>
            <p class="text-ink-muted text-xs">Title, Company</p>
          </div>
        </div>
        <!-- Testimonial 4 placeholder -->
        <div class="rounded-lg p-6 border border-border bg-surface-alt">
          <blockquote class="text-sm text-ink-light italic leading-relaxed mb-4">
            &ldquo;Client testimonial coming soon.&rdquo;
          </blockquote>
          <div class="text-sm">
            <p class="font-semibold text-ink">Client Name</p>
            <p class="text-ink-muted text-xs">Title, Company</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sectors -->
  <section class="py-10 sm:py-14 bg-surface-alt border-y border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-lg sm:text-xl mb-5">Sectors we serve</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="bg-surface rounded-lg px-4 py-3 border border-border text-center text-sm font-medium text-ink">Aerospace & Defence</div>
        <div class="bg-surface rounded-lg px-4 py-3 border border-border text-center text-sm font-medium text-ink">Medical Devices</div>
        <div class="bg-surface rounded-lg px-4 py-3 border border-border text-center text-sm font-medium text-ink">Manufacturing</div>
        <div class="bg-surface rounded-lg px-4 py-3 border border-border text-center text-sm font-medium text-ink">Healthcare</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-10 sm:py-14">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-lg sm:text-xl mb-2">Ready to see what's possible?</h2>
      <p class="text-sm text-ink-light mb-5">Start with the Breakthrough Diagnostic — 4 minutes, 6 dimensions, tailored recommendations.</p>
      <a
        href={`${base}diagnostic`}
        class="inline-flex items-center px-5 py-2.5 bg-brand text-white text-sm font-semibold rounded-lg hover:bg-brand-dark transition-colors"
      >
        Take the Diagnostic &rarr;
      </a>
    </div>
  </section>
</Layout>

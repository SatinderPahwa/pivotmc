---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Results | PIVOT Management Consultants" description="Proof, not promises. Real metrics from operational interventions.">
  <section class="py-12 sm:py-16 border-b border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="font-heading italic text-ink-muted text-sm mb-2">Results — not reports.</p>
      <h1 class="text-[1.75rem] sm:text-[2rem] lg:text-[2.25rem] text-ink mb-2">
        Proof, not promises.
      </h1>
      <p class="text-sm sm:text-base text-ink-light max-w-2xl">
        Every engagement ships measurable results. Metrics below will be populated with real, client-approved case data.
      </p>
    </div>
  </section>

  <!-- Metrics (placeholder) -->
  <section class="py-12 sm:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-lg sm:text-xl mb-6">Client outcomes</h2>
      <div class="grid sm:grid-cols-3 gap-4 mb-10">
        <div class="rounded-lg p-5 border border-border text-center">
          <p class="text-2xl font-bold text-brand mb-1">TBD</p>
          <p class="text-sm font-medium text-ink">Cycle time reduction</p>
          <p class="text-xs text-ink-muted mt-1">Lean line redesign, medical-device mfr.</p>
        </div>
        <div class="rounded-lg p-5 border border-border text-center">
          <p class="text-2xl font-bold text-brand mb-1">TBD</p>
          <p class="text-sm font-medium text-ink">Annual savings</p>
          <p class="text-xs text-ink-muted mt-1">TRIZ + Six Sigma, aerospace supplier</p>
        </div>
        <div class="rounded-lg p-5 border border-border text-center">
          <p class="text-2xl font-bold text-brand mb-1">TBD</p>
          <p class="text-sm font-medium text-ink">Audit findings</p>
          <p class="text-xs text-ink-muted mt-1">ISO 13485 readiness, MedTech firm</p>
        </div>
      </div>
      <div class="bg-surface-alt rounded-lg p-5 border border-border text-sm text-ink-muted">
        <strong class="text-ink">Note:</strong> Metric values are pending client approval. PIVOT does not publish invented numbers.
        These cards show the format — real figures (e.g. -38% cycle time, $2.4M savings, 0 major findings) will appear once confirmed.
      </div>
    </div>
  </section>

  <!-- Sectors -->
  <section class="py-10 sm:py-14 bg-surface-alt border-y border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-lg sm:text-xl mb-5">Sectors we serve</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="bg-surface rounded-lg px-4 py-3 border border-border text-center text-sm font-medium text-ink">Aerospace & Defence</div>
        <div class="bg-surface rounded-lg px-4 py-3 border border-border text-center text-sm font-medium text-ink">Medical Devices</div>
        <div class="bg-surface rounded-lg px-4 py-3 border border-border text-center text-sm font-medium text-ink">Manufacturing</div>
        <div class="bg-surface rounded-lg px-4 py-3 border border-border text-center text-sm font-medium text-ink">Healthcare</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-10 sm:py-14">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-lg sm:text-xl mb-2">Ready to see what's possible?</h2>
      <p class="text-sm text-ink-light mb-5">Start with the Breakthrough Diagnostic — 4 minutes, 6 dimensions, tailored recommendations.</p>
      <a
        href={`${base}diagnostic`}
        class="inline-flex items-center px-5 py-2.5 bg-brand text-white text-sm font-semibold rounded-lg hover:bg-brand-dark transition-colors"
      >
        Take the Diagnostic &rarr;
      </a>
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const allInsights = await getCollection('insights');
const sortedInsights = allInsights.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const listJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Insights — PIVOT Management Consultants",
  "description": "Thought leadership on TRIZ, Quality 4.0, and operational excellence from Akhilesh Gulati.",
  "url": "https://pivotmc.com/insights",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": sortedInsights.map((post, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `https://pivotmc.com/insights/${post.id}`,
      "name": post.data.title
    }))
  }
};
---

<Layout title="Insights | PIVOT Management Consultants" description="Thought leadership on TRIZ, Quality 4.0, and operational excellence from Akhilesh Gulati.">
  <script type="application/ld+json" set:html={JSON.stringify(listJsonLd)} />
  <section class="py-12 sm:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs uppercase tracking-wider text-brand font-semibold mb-2">As published in Quality Digest</p>
      <h1 class="text-[1.75rem] sm:text-[2rem] lg:text-[2.25rem] text-ink mb-2">Insights</h1>
      <p class="text-sm sm:text-base text-ink-light max-w-2xl mb-8">
        Thought leadership on TRIZ, Lean Six Sigma, Quality 4.0, and operational excellence.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {sortedInsights.map((post) => {
          const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });
          return (
            <a href={`${base}insights/${post.id}`} class="group rounded-lg p-5 border border-border hover:border-brand/40 transition-colors">
              {post.data.publication && (
                <p class="text-[0.6rem] uppercase tracking-wider text-brand font-semibold mb-1">{post.data.publication}</p>
              )}
              <h3 class="font-heading text-sm font-bold text-ink mb-1.5 group-hover:text-brand transition-colors">{post.data.title}</h3>
              <p class="text-xs text-ink-light mb-3 line-clamp-2">{post.data.description}</p>
              <div class="flex items-center justify-between text-xs text-ink-muted">
                <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
                <span class="text-brand font-medium">Read &rarr;</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Layout>

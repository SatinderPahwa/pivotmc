---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const insights = await getCollection('insights');
  return insights.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, allInsights: insights },
  }));
}

const { entry, allInsights } = Astro.props;
const { Content } = await render(entry);
const base = import.meta.env.BASE_URL;

const relatedInsights = allInsights
  .filter((p: any) => p.id !== entry.id)
  .sort((a: any, b: any) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const formattedDate = entry.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.description,
  "datePublished": entry.data.pubDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": entry.data.author,
    "url": "https://pivotmc.com/about",
    "sameAs": [
      "https://www.linkedin.com/in/akhileshgulati",
      "https://www.qualitydigest.com/author/akhilesh-gulati"
    ]
  },
  "publisher": {
    "@type": "Organization",
    "name": "PIVOT Management Consultants",
    "url": "https://pivotmc.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://pivotmc.com/insights/${entry.id}`
  },
  "keywords": entry.data.tags.join(", ")
};
---

<Layout
  title={`${entry.data.title} | PIVOT Management Consultants`}
  description={entry.data.description}
  ogType="article"
  article={{ publishedTime: entry.data.pubDate.toISOString(), author: entry.data.author, tags: entry.data.tags }}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <article class="py-12 sm:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Back link -->
      <a href={`${base}insights`} class="inline-flex items-center text-sm text-brand hover:text-brand-dark mb-8">
        &larr; All Insights
      </a>

      <!-- Header -->
      <header class="mb-8">
        {entry.data.publication && (
          <p class="text-xs uppercase tracking-wider text-brand font-semibold mb-2">
            Published in {entry.data.publication}
          </p>
        )}
        <h1 class="text-3xl sm:text-4xl text-ink mb-3">{entry.data.title}</h1>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-ink-light">
          <span>{entry.data.author}</span>
          <span>&middot;</span>
          <time datetime={entry.data.pubDate.toISOString()}>{formattedDate}</time>
        </div>
        {entry.data.tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {entry.data.tags.map((tag: string) => (
              <span class="text-xs bg-surface-alt text-ink-light px-2 py-1 rounded">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <!-- Content -->
      <div class="prose prose-slate max-w-none
        [&_h2]:font-heading [&_h2]:text-xl [&_h2]:font-bold [&_h2]:mt-8 [&_h2]:mb-3
        [&_h3]:font-heading [&_h3]:text-lg [&_h3]:font-bold [&_h3]:mt-6 [&_h3]:mb-2
        [&_p]:text-ink-light [&_p]:leading-relaxed [&_p]:mb-4
        [&_ul]:text-ink-light [&_ul]:mb-4 [&_ul]:pl-5
        [&_ol]:text-ink-light [&_ol]:mb-4 [&_ol]:pl-5
        [&_li]:mb-1
        [&_blockquote]:border-l-4 [&_blockquote]:border-brand/30 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-ink-light
        [&_strong]:text-ink
      ">
        <Content />
      </div>

      <!-- Author box -->
      <div class="mt-12 pt-8 border-t border-border">
        <div class="bg-surface-alt rounded-xl p-6">
          <p class="text-sm font-semibold text-ink mb-1">{entry.data.author}</p>
          <p class="text-sm text-ink-light mb-3">Founder & Principal Consultant, PIVOT Management Consultants</p>
          <div class="flex gap-4 text-sm">
            <a href="https://www.linkedin.com/in/akhileshgulati" target="_blank" rel="noopener noreferrer" class="text-brand hover:text-brand-dark font-medium">LinkedIn</a>
            <a href="https://www.qualitydigest.com/author/akhilesh-gulati" target="_blank" rel="noopener noreferrer" class="text-brand hover:text-brand-dark font-medium">Quality Digest</a>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-10 rounded-lg border border-brand/20 bg-brand-light p-6 text-center">
        <p class="text-sm font-semibold text-ink mb-1">Ready to break through your plateau?</p>
        <p class="text-xs text-ink-light mb-4">The Breakthrough Diagnostic scores your operation across 6 dimensions in 4 minutes.</p>
        <a href={`${base}diagnostic`} class="inline-flex items-center px-5 py-2.5 bg-brand text-white text-sm font-semibold rounded-lg hover:bg-brand-dark transition-colors">
          Take the Diagnostic &rarr;
        </a>
      </div>

      <!-- Related insights -->
      <div class="mt-10">
        <h3 class="font-heading text-base font-bold text-ink mb-4">More insights</h3>
        <div class="grid gap-3">
          {relatedInsights.map((post: any) => (
            <a href={`${base}insights/${post.id}`} class="group flex items-center justify-between rounded-lg p-4 border border-border hover:border-brand/40 transition-colors">
              <div>
                <p class="text-sm font-medium text-ink group-hover:text-brand transition-colors">{post.data.title}</p>
                <p class="text-xs text-ink-muted mt-0.5">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
              </div>
              <span class="text-brand text-sm font-medium ml-4 shrink-0">&rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </article>
</Layout>

---
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;

const exploreLinks = [
  { href: `${base}triz`, label: 'The TRIZ Advantage' },
  { href: `${base}results`, label: 'Results' },
  { href: `${base}insights`, label: 'Insights' },
  { href: `${base}diagnostic`, label: 'Breakthrough Diagnostic' },
];

const companyLinks = [
  { href: `${base}services`, label: 'Services' },
  { href: `${base}about`, label: 'About' },
  { href: `${base}contact`, label: 'Contact' },
  { href: `${base}privacy`, label: 'Privacy Policy' },
];
---

<footer class="bg-surface-dark text-white/70">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-6">
      <!-- Brand + contact -->
      <div class="sm:col-span-2">
        <a href={base} class="font-heading text-base font-bold text-white">
          PIVOT<span class="text-brand">MC</span>
        </a>
        <p class="mt-2 text-xs leading-relaxed">
          Results — not reports. Operations consulting powered by TRIZ.
        </p>
        <div class="mt-3 space-y-0.5 text-xs">
          <p><a href="mailto:gulati@pivotmc.com" class="hover:text-white transition-colors">gulati@pivotmc.com</a></p>
          <p><a href="tel:+18779486862" class="hover:text-white transition-colors">1-877-PIVOTMC</a> &middot; <a href="tel:+19099859294" class="hover:text-white transition-colors">1-909-985-9294</a></p>
        </div>
      </div>

      <!-- Explore -->
      <div>
        <h4 class="text-xs font-bold text-white uppercase tracking-wider mb-2">Explore</h4>
        <ul class="space-y-1 text-xs">
          {exploreLinks.map(({ href, label }) => (
            <li><a href={href} class="hover:text-white transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-xs font-bold text-white uppercase tracking-wider mb-2">Company</h4>
        <ul class="space-y-1 text-xs">
          {companyLinks.map(({ href, label }) => (
            <li><a href={href} class="hover:text-white transition-colors">{label}</a></li>
          ))}
        </ul>
        <a
          href="https://www.linkedin.com/company/pivot-management-consultants"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-xs mt-3 hover:text-white transition-colors"
          aria-label="LinkedIn"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>

    <div class="mt-6 pt-4 border-t border-white/10 text-center text-[0.65rem] text-white/40">
      &copy; {currentYear} PIVOT Management Consultants. All rights reserved.
    </div>
  </div>
</footer>
